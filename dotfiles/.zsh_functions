_review_base_branch() {
  local ref

  for ref in main master origin/main origin/master upstream/main upstream/master; do
    if git rev-parse --verify --quiet "${ref}^{commit}" >/dev/null 2>&1; then
      print -r -- "$ref"
      return 0
    fi
  done

  print -u2 "review: could not find a main or master base branch"
  return 1
}

_codex_review() {
  local -a pipeline_status

  codex exec --ephemeral --color always review \
    -m gpt-5.5 \
    -c 'model_reasoning_effort="medium"' \
    -c 'service_tier="fast"' \
    "$@"

  pipeline_status=("${pipestatus[@]}")
  return "${pipeline_status[1]}"
}

review() {
  local base

  base="$(_review_base_branch)" || return
  _codex_review --base "$base" "$@"
}

review-commit() {
  _codex_review --uncommitted "$@"
}

muse() {
  local tool="$1"
  mise use --global "$tool@$(mise latest "$tool")"
}
